    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "vitest-canvas-mock": "^1.1.4"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "undici": "^7.24.1"
  }
