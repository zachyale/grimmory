{
  "name": "grimmory",
  "version": "0.0.0",
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "dev": "ng serve --open --watch --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "coverage": "ng test --watch=false --coverage",
    "coverage:summary": "node ./scripts/coverage-summary.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "yarn lint:eslint && yarn lint:styles",
    "lint:eslint": "ng lint",
    "lint:styles": "stylelint \"src/**/*.scss\" \"src/*.scss\"",
    "lint:styles:fix": "yarn lint:styles --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.6",
    "@angular/cdk-experimental": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.7",
    "@embedpdf/pdfium": "2.14.0",
    "@embedpdf/snippet": "2.14.0",
    "@jsverse/transloco": "^8.2.1",
    "@primeuix/themes": "^2.0.3",
    "@stomp/rx-stomp": "^2.3.0",
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/angular-query-experimental": "5.96.2",
    "@tweenjs/tween.js": "^25.0.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-matrix": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "jwt-decode": "^4.0.0",
    "ng-lazyload-image": "^9.1.3",
    "ng2-charts": "^10.0.0",
    "ngx-extended-pdf-viewer": "^26.0.0",
    "ngx-infinite-scroll": "^21.0.0",
    "ngx-sse-client": "^21.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "^7.8.2",
    "showdown": "^2.1.0",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "ws": "^8.20.0"
